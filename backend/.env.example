# 数据库配置
DATABASE_URL=postgresql+asyncpg://admin:your_secure_password@localhost:5432/customer_service
REDIS_URL=redis://localhost:6379/0
MILVUS_HOST=localhost
MILVUS_PORT=19530

# OpenAI-compatible 对话模型配置
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://xxx.com/v1
LLM_MODEL=xxx
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.2

# OpenAI-compatible 向量模型配置
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_BASE_URL=https://xxx.com/v1
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1536

# 业务配置
MAX_CONTEXT_MESSAGES=10
CONTACT_COLLECTION_THRESHOLD=3

# 产品数据接口
PRODUCT_API_URL=https://xxx.com/api/products
PRODUCT_API_KEY=your_api_key
